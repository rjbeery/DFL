# backend/.env.example — DFL backend environment configuration
#
# Copy to .env and fill in real values before starting the backend.
#   cp .env.example .env
#   nano .env
#
# The systemd service (scripts/dfl-backend.service) loads this file via
# EnvironmentFile=/opt/dfl/backend/.env
#
# SECURITY: .env is gitignored. Never commit real secrets.

# ── Server bind ───────────────────────────────────────────────────────────────
# 0.0.0.0 = accept connections from any interface (required for remote access).
# Change to 127.0.0.1 if nginx handles external traffic and proxies to the backend.
DFL_BIND_HOST=0.0.0.0
DFL_BIND_PORT=8000

# ── Authentication ────────────────────────────────────────────────────────────
# Required before exposing the UI on a public IP.

# Enable the password login gate.
DFL_AUTH_ENABLED=true

# Browser login password. Use 20+ random characters.
DFL_AUTH_PASSWORD=change-me-before-deploying

# Secret for signing session cookies. Must be stable across restarts.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
DFL_SESSION_SECRET=replace-with-64-char-hex-string

# Optional API bearer token for curl/scripted access.
# When set, requests carrying  X-DFL-Token: <value>  bypass the login page.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to disable token auth.
DFL_API_TOKEN=

# Set to "true" only when the backend is behind a TLS terminator (nginx + certs).
# Adds Secure flag to session cookies.
DFL_HTTPS_ONLY=false

# ── Workspace and storage paths ───────────────────────────────────────────────
# These must be absolute paths on the VM host that the backend process can read.
# They are also bind-mounted into DFL Docker containers as /workspace.

DFL_WORKSPACE=/mnt/disks/workspace
DFL_BACKUP=/mnt/disks/backups
DFL_STORAGE_BACKEND=local

# ── Docker image ──────────────────────────────────────────────────────────────
# Tag of the DFL runtime image built from the repo Dockerfile.
DFL_DOCKER_IMAGE=dfl:latest

# GPU flag(s) passed to `docker run`. Set to empty string to disable GPU passthrough.
DFL_DOCKER_GPU=--gpus all

# Any additional `docker run` flags (optional).
DFL_DOCKER_EXTRA=
