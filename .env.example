# .env.example — DFL wrapper configuration template
#
# Copy to .env and fill in real values before running docker compose.
# The .env file is gitignored; this file is safe to commit (no real secrets).
#
# Usage:
#   cp .env.example .env
#   nano .env          # fill in passwords and paths
#   docker compose up -d --build

# ── Storage paths (host-side mount points) ────────────────────────────────────
#
# These are the paths on the HOST machine that get bind-mounted into the containers.
# Change them to wherever your disks are mounted on the cloud VM.
#
# Local defaults (Windows):
#   DFL_WORKSPACE_HOST=C:/Users/Rod/Documents/DFL/workspace
#   DFL_BACKUP_HOST=C:/Users/Rod/Documents/DFL/backups
#
# Cloud VM defaults (Linux, typical attached-disk layout):
DFL_WORKSPACE_HOST=/mnt/disks/workspace
DFL_BACKUP_HOST=/mnt/disks/backups

# ── Authentication ────────────────────────────────────────────────────────────
#
# REQUIRED before exposing the UI to the internet.
# When DFL_AUTH_ENABLED is not "true", a visible warning banner is shown and
# all routes are open — acceptable for private/local use only.

# Set to "true" to enable the password login gate.
DFL_AUTH_ENABLED=true

# Shared password for the web UI.  Anyone with this can launch DFL stages.
# Use a password manager to generate something strong (20+ random chars).
DFL_AUTH_PASSWORD=change-me-before-deploying

# Random secret for signing session cookies.  Must stay constant across restarts
# (changing it invalidates all active sessions).
# Generate a value:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
DFL_SESSION_SECRET=replace-with-64-char-hex-string-generated-above

# ── TLS / HTTPS (Phase 2 — after certs are provisioned) ──────────────────────
#
# Leave as "false" during initial HTTP bring-up.
# Set to "true" after uncommenting the HTTPS server block in nginx/nginx.conf
# and mounting certificates — this adds the Secure flag to session cookies.
DFL_HTTPS_ONLY=false
